# Environment Variables Template
# Copy to .env and fill in your values

# ── Backend ────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# Groq API Key (for Whisper transcription)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (for AI translation)
GEMINI_API_KEY=your_gemini_api_key_here

# APIhut API Key (for social media video downloads — YouTube, Instagram, Facebook, Twitter, LinkedIn, TikTok)
# Get yours free at https://apihut.in/signup
APIHUT_API_KEY=your_apihut_api_key_here

# Frontend URL (for CORS) — Vercel frontend URL
ALLOWED_ORIGIN=https://your-frontend.vercel.app

# ── Paths (usually don't need to change) ─────────────────────────────────
PROJECT_ROOT=/app
