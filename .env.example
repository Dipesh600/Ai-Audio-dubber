# ══════════════════════════════════════════════════════════════════════
# Setu Dubber — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════

# ── Backend ──────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# Groq API Key (for Whisper transcription)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (for AI translation + emotion tagging)
GEMINI_API_KEY=your_gemini_api_key_here

# APIhut API Key (for Instagram, TikTok, Twitter, LinkedIn, Facebook downloads)
# Get yours free at https://apihut.in/signup
APIHUT_API_KEY=your_apihut_api_key_here

# Frontend URL (for CORS — set to your Vercel domain in production)
ALLOWED_ORIGIN=https://your-app.vercel.app

# ── Azure Blob Storage (for persistent video storage) ───────────────
# Get from: Azure Portal → Storage Account → Access Keys → Connection String
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=setu-dubber

# ── Paths (auto-set in Docker, override only if needed) ──────────────
PROJECT_ROOT=/app
